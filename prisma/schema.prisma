generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}



model User{ 
  id BigInt @id 
  name String

  steps Step[]
}

model Theme{
  id Int @id @default(autoincrement())
  name String

  steps Step[]

  cases ThemesOnCases[]
  papers ThemesOnPapers[]
}

model Answer{
  id Int @id @default(autoincrement())
  name String

  cases AnswersOnCases[]
}

model Pain{
  id Int @id @default(autoincrement())
  name String

  cases Case[]
}

model Case{
  id Int @id @default(autoincrement())
  title String
  exam String
  history String
  background String

  pain Pain @relation(fields: [painId], references:[id])
  painId Int

  images Image[]
  steps Step[]

  answers AnswersOnCases[]
  themes ThemesOnCases[]
}

model AnswersOnCases{
  answer Answer @relation(fields: [answerId], references: [id])
  answerId Int
  case Case @relation(fields: [caseId], references: [id])
  caseId Int

  isCorrect Boolean

  @@id([answerId,caseId])
}

model ThemesOnCases{
  theme Theme @relation(fields: [themeId], references: [id])
  themeId Int
  case Case @relation(fields: [caseId], references: [id])
  caseId Int

  @@id([themeId,caseId])
}

model Paper{
  id Int @id @default(autoincrement())
  title String
  autor String

  steps Step[]
  embeddings Embedding[]

  themes ThemesOnPapers[]
}

model ThemesOnPapers{
  theme Theme @relation(fields: [themeId], references: [id])
  themeId Int
  paper Paper @relation(  fields: [paperId], references: [id])
  paperId Int

  @@id([themeId,paperId])
}

model Image{
  id Int @id @default(autoincrement())
  title String
  type Boolean
  info String
  url String

  case Case @relation(fields: [caseId], references: [id])
  caseId Int
}

model Step{
  id Int @id @default(autoincrement())
  errors Int

  user User @relation(fields: [userId], references: [id])
  userId BigInt
  theme Theme @relation(fields: [themeId], references: [id])
  themeId Int
  case Case @relation(fields: [caseId], references: [id])
  caseId Int
  paper Paper @relation(fields: [paperId], references: [id])
  paperId Int
}


model Embedding{
  id Int @id @default(autoincrement())
  vector Unsupported("vector")

  paper Paper @relation(fields: [paperId],references: [id])
  paperId Int
}




