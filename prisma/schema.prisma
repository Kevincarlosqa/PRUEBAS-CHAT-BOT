generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// INFO
  model Info{
    id Int @id @default(autoincrement())
    title String @unique
    autor String
    embeddings Embedding[]
    topics InfoOnTopics[]
  }

  model Embedding{
    id Int @id @default(autoincrement())
    info Info @relation(fields: [idInfo],references: [id])
    idInfo Int
    vector Unsupported("vector")
  }

  model InfoOnTopics{
    info Info @relation(fields: [idInfo], references: [id])
    idInfo Int
    topic Topic @relation(fields: [idTopic], references: [id])
    idTopic Int

    @@id([idInfo,idTopic])
  }


// TOPICS
  model Topic{
    id Int @id @default(autoincrement())
    dentalCase CasesOnTopics[]
    info InfoOnTopics[]
    name String
  }

  model CasesOnTopics{
    dentalCase DentalCase @relation(fields: [idCase], references: [id])
    idCase Int
    topic Topic @relation(fields: [idTopic], references: [id])
    idTopic Int

    @@id([idCase,idTopic])
  }

// CASOS

  model DentalCase{
    id Int @id @default(autoincrement())
    title String @unique
    ante String
    exam String
    ans String
    images Image[]
    topics CasesOnTopics[]
  }

  model Image{
    id Int @id @default(autoincrement())
    name String
    type Int
    url String
    dentalCase DentalCase @relation(fields: [idCase],references: [id])
    idCase Int
  }
  


