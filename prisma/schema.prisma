generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// USUARIOS

  model User{
    id BigInt @id
    stage_id Int
    book_id Int
    case_id Int
  }

// BIBLIOGRAFIA

  model Biblio{
    id Int @id @default(autoincrement())
    title String @unique
    autor String
    type TypeBiblio @relation(fields: [type_id],references: [id])
    type_id Int
    embeddings Embedding[]
    temas BibliosOnTemas[]
  }

  model TypeBiblio{
    id Int @id @default(autoincrement())
    biblios Biblio[]
    name String
  }

  model Embedding{
    id Int @id @default(autoincrement())
    biblio Biblio @relation(fields: [biblio_id],references: [id])
    biblio_id Int
    vector Unsupported("vector")
  }

// CASOS

  model Case{
    id Int @id @default(autoincrement())
    title String
    ante String
    exam String
    images Image[]
    temas CasesOnTemas[]
    // books CasesOnBooks[]
  }

  model Image{
    id Int @id @default(autoincrement())
    tipo Int
    url String
    case Case @relation(fields: [case_id],references: [id])
    case_id Int
  }
  

// TEMAS
  model Tema{
    id Int @id @default(autoincrement())
    cases CasesOnTemas[]
    biblios BibliosOnTemas[]
    nombre String
  }

  model CasesOnTemas{
    case Case @relation(fields: [case_id], references: [id])
    case_id Int
    tema Tema @relation(fields: [tema_id], references: [id])
    tema_id Int

    @@id([case_id,tema_id])
  }

  model BibliosOnTemas{
    biblio Biblio @relation(fields: [biblio_id], references: [id])
    biblio_id Int
    tema Tema @relation(fields: [tema_id], references: [id])
    tema_id Int

    @@id([biblio_id,tema_id])
  }


